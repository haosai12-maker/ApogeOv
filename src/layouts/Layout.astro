---
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = "ApogeOv — Ropa Oversize Premium Medellín | Tienda Online Colombia",
  description = "Tienda online de ropa oversize premium en Medellín. Tela burda de alto gramaje. Envío gratis Valle de Aburrá. Paga cuando llega a tu casa.",
  canonicalUrl = "https://apogeov.com",
  ogImage = "/images/Og Web.png",
  noindex = false,
} = Astro.props;

const siteUrl = "https://apogeov.com";
const fullCanonical = canonicalUrl.startsWith("http") ? canonicalUrl : `${siteUrl}${canonicalUrl}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030213" />
    <meta name="generator" content={Astro.generator} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={fullCanonical} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="ApogeOv" />
    <meta property="og:locale" content="es_CO" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@apogeov" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

<script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "ApogeOv",
        "url": "https://apogeov.com",
        "logo": "https://apogeov.com/favicon.ico",
        "description": "Tienda online de ropa oversize premium en Medellín. Tela burda de alto gramaje. Envío gratis Valle de Aburrá. Paga cuando llega a tu casa.",
        "sameAs": [
          "https://www.instagram.com/apogeov/",
          "https://www.tiktok.com/@apogeov",
          "https://www.facebook.com/profile.php?id=61590387307491",
          "https://www.youtube.com/@ApogeOv"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+573148499976",
          "contactType": "customer service",
          "areaServed": "CO",
          "availableLanguage": ["Spanish"]
        },
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Medellín",
          "addressRegion": "Antioquia",
          "addressCountry": "CO"
        }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Store",
        "name": "ApogeOv",
        "description": "Tienda online de ropa oversize premium en Medellín. Camisetas, sudaderas y combos de alta calidad para hombre.",
        "url": "https://apogeov.com",
        "logo": "https://apogeov.com/favicon.ico",
        "image": "https://apogeov.com/images/Og Web.png",
        "priceRange": "$$",
        "telephone": "+573148499976",
        "email": "apogeov@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Medellín",
          "addressRegion": "Antioquia",
          "postalCode": "050001",
          "addressCountry": "CO"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 6.2442,
          "longitude": -75.5812
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
            "opens": "09:00",
            "closes": "19:00"
          }
        ],
        "sameAs": [
          "https://www.instagram.com/apogeov/",
          "https://www.tiktok.com/@apogeov",
          "https://www.facebook.com/profile.php?id=61590387307491",
          "https://www.youtube.com/@ApogeOv"
        ]
      }
    </script>
  </head>
  <body class="min-h-screen bg-background antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-foreground focus:text-background focus:font-medium focus:rounded-md focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
    >
      Saltar al contenido principal
    </a>

    <a
      href="https://wa.me/573148499976?text=%C2%A1Hola!%20Me%20interesa%20un%20producto%20de%20ApogeOv."
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Escríbenos por WhatsApp"
      class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 rounded-full bg-green-500 shadow-lg hover:bg-green-600 transition-colors"
    >
      <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <slot />
    <script is:inline>
      (function () {
        var DURATION = 650;

        function easeInOutCubic(t) {
          return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
        }

        function animateScrollTo(targetY) {
          var startY = window.pageYOffset;
          var distance = targetY - startY;
          var startTime = performance.now();

          function step(now) {
            var elapsed = now - startTime;
            var progress = Math.min(elapsed / DURATION, 1);
            window.scrollTo(0, startY + distance * easeInOutCubic(progress));
            if (progress < 1) requestAnimationFrame(step);
          }

          requestAnimationFrame(step);
        }

        document.addEventListener("click", function (e) {
          var link = e.target.closest("a[href]");
          if (!link) return;

          var href = link.getAttribute("href");
          if (!href || href.indexOf("#") === -1) return;

          var hashIndex = href.indexOf("#");
          var pathPart = href.slice(0, hashIndex) || window.location.pathname;
          var hash = href.slice(hashIndex);
          var onHome =
            window.location.pathname === "/" ||
            window.location.pathname.endsWith("index.html");

          if (pathPart && pathPart !== "/" && pathPart !== window.location.pathname) {
            return;
          }

          if (!onHome && pathPart === "/") return;

          e.preventDefault();

          if (hash === "#") {
            animateScrollTo(0);
            history.pushState(null, "", "/");
            return;
          }

          var target = document.querySelector(hash);
          if (!target) return;

          var nav = document.querySelector("nav");
          var offset = (nav ? nav.offsetHeight : 80) + 16;
          var top = target.getBoundingClientRect().top + window.pageYOffset - offset;

          animateScrollTo(top);
          history.pushState(null, "", hash);
        });
      })();
    </script>
  </body>
</html>