---
// @ts-nocheck
import Icon from "../Icon.astro";
---

<section class="bg-foreground text-white py-12 lg:py-16">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-[100px]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 divide-y md:divide-y-0 md:divide-x divide-white/10 stagger-children">
      <div class="trust-item group py-6 md:py-0 md:px-8 lg:px-12">
        <div class="trust-item__icon">
          <Icon name="map-pin" class="w-5 h-5" />
        </div>
        <div>
          <h4 class="font-display text-lg uppercase tracking-tight mb-1">Envíos Gratis</h4>
          <p class="text-xs text-white/50 normal-case font-normal tracking-normal">
            A todo el Valle de Aburrá
          </p>
        </div>
      </div>

      <div class="trust-item group py-6 md:py-0 md:px-8 lg:px-12">
        <div class="trust-item__icon">
          <Icon name="credit-card" class="w-5 h-5" />
        </div>
        <div>
          <h4 class="font-display text-lg uppercase tracking-tight mb-1">Pago Contraentrega</h4>
          <p class="text-xs text-white/50 normal-case font-normal tracking-normal">
            Paga cuando recibas tu pedido
          </p>
        </div>
      </div>

      <div class="trust-item group py-6 md:py-0 md:px-8 lg:px-12">
        <div class="trust-item__icon">
          <Icon name="ruler" class="w-5 h-5" />
        </div>
        <div>
          <h4 class="font-display text-lg uppercase tracking-tight mb-1">Guía de Tallas</h4>
          <p class="text-xs text-white/50 normal-case font-normal tracking-normal">
            Encuentra tu fit oversize perfecto
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .trust-item__icon {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .trust-item:hover .trust-item__icon {
    background: var(--accent);
    color: var(--accent-foreground);
    transform: scale(1.05);
  }

  @media (min-width: 768px) {
    .trust-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }

    .trust-item__icon {
      width: 3.5rem;
      height: 3.5rem;
    }
  }
</style>
