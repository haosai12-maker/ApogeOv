---
// @ts-nocheck
import { loadProducts } from "../../data/load-products";

const products = loadProducts();
const productsJson = JSON.stringify(products);

function getCardClass(index: number): string {
  if (index === 0) return "editorial-card--hero";
  if (index === 3 || index === 7) return "editorial-card--wide";
  if (index === 5) return "editorial-card--tall";
  return "";
}

---

<section class="bg-background py-20 lg:py-32" id="catalogo">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-[100px]">
    <div class="mb-10 md:mb-16 reveal-up">
      <span class="inline-block text-xs uppercase tracking-[0.2em] text-accent font-bold mb-2">
        Colección
      </span>
      <h2 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl uppercase tracking-tight">
        Oversize Premium
      </h2>
      <p class="text-sm md:text-base text-muted-foreground normal-case font-normal tracking-normal mt-2 max-w-lg">
        Prendas de alto gramaje con fit relajado. Hecho en Medellín.
      </p>
    </div>

    <div class="editorial-grid stagger-children" data-product-grid>
      {
        products.map((product, index) => {
          const cardClass = getCardClass(index);
          const primaryImage = product.images[0] ?? "";
          const hoverImage = product.images[1] ?? "";
          const hasHover = hoverImage.length > 0;

          return (
            <article
              class={`editorial-card ${cardClass} ${!hasHover ? "editorial-card--single" : ""}`}
              data-product-id={product.id}
              tabindex="0"
              role="button"
              aria-label={`Ver detalle de ${product.name}`}
            >
              <img
                src={primaryImage}
                alt={`${product.name} — vista frontal`}
                class="editorial-card__image editorial-card__image--primary"
                loading={index <= 2 ? "eager" : "lazy"}
                decoding="async"
              />

              {hasHover && (
                <img
                  src={hoverImage}
                  alt={`${product.name} — vista detalle`}
                  class="editorial-card__image editorial-card__image--hover"
                  loading="lazy"
                  decoding="async"
                />
              )}

              <div class="editorial-card__overlay" aria-hidden="true"></div>

              <div class="editorial-card__content">
                <span class="editorial-card__badge">
                  {product.fabric}
                </span>
                <h3 class="editorial-card__name">
                  {product.name}
                </h3>
                <p class="editorial-card__price">
                  ${product.price} COP
                </p>
              </div>

              <div class="editorial-card__quick-view" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                </svg>
              </div>
            </article>
          );
        })
      }
    </div>

    <p class="text-center mt-12 text-sm lg:text-base text-muted-foreground normal-case font-normal tracking-normal reveal-up">
      ¿No encuentras lo que buscas?
      <a
        href="https://wa.me/573108150734"
        target="_blank"
        rel="noopener noreferrer"
        class="underline hover:text-accent transition-colors"
      >
        Escríbenos al WhatsApp
      </a>
      y descubre todos nuestros productos disponibles.
    </p>
  </div>
</section>

<div
  id="product-modal"
  class="product-modal"
  hidden
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="product-modal-title"
>
  <div class="product-modal__backdrop" data-modal-close tabindex="-1"></div>

  <div class="product-modal__panel">
    <button
      type="button"
      class="product-modal__close"
      data-modal-close
      aria-label="Cerrar detalle del producto"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12" />
      </svg>
    </button>

    <div class="product-modal__grid">
      <div class="product-modal__media">
        <div id="product-modal-carousel-host" class="product-modal__carousel-host"></div>
        <span
          id="product-modal-fabric"
          class="absolute top-4 left-4 z-10 inline-block px-3 py-1 text-xs uppercase tracking-wider bg-accent text-accent-foreground"
        ></span>
      </div>

      <div class="product-modal__content">
        <p class="text-xs uppercase tracking-[0.2em] text-accent font-bold mb-2">Detalle del producto</p>
        <h3 id="product-modal-title" class="font-display text-3xl lg:text-4xl font-bold uppercase mb-3 tracking-tight"></h3>
        <p id="product-modal-price" class="text-3xl font-black mb-5 normal-case tracking-normal text-accent"></p>
        <p id="product-modal-description" class="text-muted-foreground normal-case font-normal tracking-normal mb-6 leading-relaxed"></p>

        <div class="mb-6">
          <h4 class="text-xs uppercase tracking-wider mb-3">Tallas</h4>
          <div id="product-modal-sizes" class="flex flex-wrap gap-2"></div>
        </div>

        <div class="mb-8">
          <h4 class="text-xs uppercase tracking-wider mb-3">Características</h4>
          <ul id="product-modal-details" class="space-y-2 text-sm text-muted-foreground normal-case font-normal tracking-normal"></ul>
        </div>

        <a
          id="product-modal-whatsapp"
          href="https://wa.me/573108150734"
          target="_blank"
          rel="noopener noreferrer"
          class="w-full bg-green-500 text-white py-4 text-sm uppercase tracking-wider hover:bg-green-600 transition-colors text-center block"
        >
          Comprar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  import { initProductCarousels } from "../../scripts/product-carousel.ts";

  window.__initProductCarousels = initProductCarousels;

  const runCarousels = () => initProductCarousels(document);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", runCarousels);
  } else {
    runCarousels();
  }
  document.addEventListener("astro:page-load", runCarousels);
</script>

<script define:vars={{ productsJson }}>
  const catalog = JSON.parse(productsJson);
  const catalogById = Object.fromEntries(catalog.map((p) => [p.id, p]));

  const modal = document.getElementById("product-modal");
  const modalCarouselHost = document.getElementById("product-modal-carousel-host");
  const modalFabric = document.getElementById("product-modal-fabric");
  const modalTitle = document.getElementById("product-modal-title");
  const modalPrice = document.getElementById("product-modal-price");
  const modalDescription = document.getElementById("product-modal-description");
  const modalSizes = document.getElementById("product-modal-sizes");
  const modalDetails = document.getElementById("product-modal-details");

  let lastFocused = null;
  let focusTrapCleanup = null;
  let selectedSize = "";

  function trapFocus(element) {
    const focusableSelectors = [
      'button:not([disabled])',
      'input:not([disabled])',
      'select:not([disabled])',
      'textarea:not([disabled])',
      'a[href]',
      '[tabindex]:not([tabindex="-1"])',
    ].join(', ');

    const focusableElements = element.querySelectorAll(focusableSelectors);
    const firstFocusable = focusableElements[0];
    const lastFocusable = focusableElements[focusableElements.length - 1];

    function handleKeydown(e) {
      if (e.key !== 'Tab') return;
      if (e.shiftKey) {
        if (document.activeElement === firstFocusable) {
          e.preventDefault();
          lastFocusable?.focus();
        }
      } else {
        if (document.activeElement === lastFocusable) {
          e.preventDefault();
          firstFocusable?.focus();
        }
      }
    }

    element.addEventListener('keydown', handleKeydown);
    firstFocusable?.focus();

    return () => element.removeEventListener('keydown', handleKeydown);
  }

  function buildCarouselHtml(images, alt, compact) {
    if (!images?.length) {
      return `<div class="product-carousel product-carousel--empty"><span class="text-xs uppercase tracking-wider text-muted-foreground">Sin imagen</span></div>`;
    }

    const slides = images
      .map(
        (src, i) => `
      <div class="product-carousel__slide${i === 0 ? " is-active" : ""}" data-carousel-slide data-index="${i}">
        <img src="${src}" alt="${alt} — foto ${i + 1}" class="product-carousel__img" loading="${i === 0 ? "eager" : "lazy"}" decoding="async" draggable="false" />
      </div>`
      )
      .join("");

    const nav =
      images.length > 1
        ? `<div class="product-carousel__controls">
      <button type="button" class="product-carousel__nav product-carousel__nav--prev" data-carousel-prev aria-label="Foto anterior">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button type="button" class="product-carousel__nav product-carousel__nav--next" data-carousel-next aria-label="Foto siguiente">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <div class="product-carousel__counter" data-carousel-counter>1 / ${images.length}</div>
    </div>`
        : "";

    const dots =
      images.length > 1
        ? `<div class="product-carousel__dots" data-carousel-dots>${images
            .map(
              (_, i) =>
                `<button type="button" class="product-carousel__dot${i === 0 ? " is-active" : ""}" data-carousel-dot="${i}" aria-label="Ir a foto ${i + 1}"></button>`
            )
            .join("")}</div>`
        : "";

    return `
      <div class="product-carousel${compact ? " product-carousel--compact" : ""}" data-product-carousel>
        <div class="product-carousel__viewport">
          <div class="product-carousel__track" data-carousel-track>${slides}</div>
        </div>
        ${nav}
        ${dots}
      </div>`;
  }

  function renderSizes(sizes) {
    modalSizes.innerHTML = "";
    sizes.forEach((size) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.textContent = size;
      btn.dataset.size = size;
      btn.className =
        "min-w-[3rem] px-3 py-2 text-sm border border-border uppercase tracking-wide transition-colors hover:border-accent cursor-pointer bg-transparent text-white";
      btn.addEventListener("click", () => {
        selectedSize = size;
        modalSizes.querySelectorAll("button").forEach((b) => {
          b.className =
            "min-w-[3rem] px-3 py-2 text-sm border border-border uppercase tracking-wide transition-colors hover:border-accent cursor-pointer bg-transparent text-white";
        });
        btn.className =
          "min-w-[3rem] px-3 py-2 text-sm border uppercase tracking-wide transition-colors cursor-pointer bg-accent text-accent-foreground border-accent";
        updateWhatsAppLink();
      });
      modalSizes.appendChild(btn);
    });
  }

  function renderDetails(details) {
    modalDetails.innerHTML = "";
    details.forEach((detail) => {
      const li = document.createElement("li");
      li.className = "flex items-center gap-2";
      li.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0" aria-hidden="true"></span>${detail}`;
      modalDetails.appendChild(li);
    });
  }

  function updateWhatsAppLink() {
    const whatsappLink = document.getElementById("product-modal-whatsapp");
    const title = modalTitle?.textContent || "";
    const price = modalPrice?.textContent || "";
    if (whatsappLink) {
      const message = `¡Hola! Me interesa este producto:%0A%0A*${title}*%0APrecio: ${price}%0ATalla: ${selectedSize || "Por confirmar"}%0A%0AMe gustaría reservarlo, ¿está disponible?`;
      whatsappLink.href = `https://wa.me/573108150734?text=${message}`;
    }
  }

  function openProduct(id) {
    const product = catalogById[id];
    if (!product || !modal) return;

    selectedSize = "";

    modalCarouselHost.innerHTML = buildCarouselHtml(product.images, product.name, false);
    requestAnimationFrame(() => {
      window.__initProductCarousels?.(modalCarouselHost);
    });

    modalFabric.textContent = product.fabric;
    modalTitle.textContent = product.name;
    modalPrice.textContent = `$${product.price} COP`;
    modalDescription.textContent = product.description;

    renderSizes(product.sizes);
    renderDetails(product.details);
    updateWhatsAppLink();

    lastFocused = document.activeElement;
    modal.hidden = false;
    modal.setAttribute("aria-hidden", "false");
    document.body.classList.add("product-modal-open");

    focusTrapCleanup = trapFocus(modal);
  }

  function closeModal() {
    if (!modal) return;
    modal.hidden = true;
    modal.setAttribute("aria-hidden", "true");
    document.body.classList.remove("product-modal-open");
    modalCarouselHost.innerHTML = "";

    focusTrapCleanup?.();
    focusTrapCleanup = null;

    lastFocused?.focus?.();
  }

  function bindProductCards() {
    document.querySelectorAll("[data-product-id]").forEach((card) => {
      const id = card.getAttribute("data-product-id");
      if (!id || card.dataset.cardBound === "true") return;
      card.dataset.cardBound = "true";

      card.addEventListener("click", (e) => {
        if (
          e.target.closest("[data-carousel-prev]") ||
          e.target.closest("[data-carousel-next]") ||
          e.target.closest("[data-carousel-dot]")
        ) {
          return;
        }
        openProduct(id);
      });

      card.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          openProduct(id);
        }
      });
    });
  }

  function setupProducts() {
    bindProductCards();
  }

  modal?.querySelectorAll("[data-modal-close]").forEach((el) => {
    el.addEventListener("click", closeModal);
  });

  document.getElementById("product-modal-whatsapp")?.addEventListener("click", () => {
    updateWhatsAppLink();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && !modal.hidden) closeModal();
  });

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupProducts);
  } else {
    setupProducts();
  }
  document.addEventListener("astro:page-load", setupProducts);
</script>

<style>
  .product-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0;
  }

  .product-modal[hidden] {
    display: none;
  }

  .product-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.6);
    backdrop-filter: blur(6px);
  }

  .product-modal__panel {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 64rem;
    max-height: 94vh;
    overflow-y: auto;
    background: var(--background);
    border-top: 1px solid var(--border);
  }

  @media (min-width: 768px) {
    .product-modal {
      align-items: center;
      padding: 2rem;
    }
    .product-modal__panel {
      border: 1px solid var(--border);
    }
  }

  .product-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--background);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.2s;
  }

  .product-modal__close:hover {
    background: var(--accent);
    color: var(--accent-foreground);
    border-color: var(--accent);
  }

  .product-modal__grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .product-modal__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .product-modal__media {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--muted);
    min-height: 320px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .product-modal__media {
      aspect-ratio: auto;
      min-height: 480px;
      height: 100%;
    }
  }

  .product-modal__content {
    padding: 2rem 1.5rem;
  }

  @media (min-width: 768px) {
    .product-modal__content {
      padding: 2.5rem 2rem;
    }
  }

  .product-modal__carousel-host {
    position: absolute;
    inset: 0;
  }

  .product-modal__carousel-host .product-carousel {
    position: absolute;
    inset: 0;
  }

  .product-modal__carousel-host .product-carousel__dots {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgb(0 0 0 / 0.45);
  }

  .product-modal__carousel-host .product-carousel__dot {
    background: rgb(255 255 255 / 0.4);
  }

  .product-modal__carousel-host .product-carousel__dot.is-active {
    background: var(--accent);
  }
</style>
