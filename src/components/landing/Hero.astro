---
// @ts-nocheck
import { heroImage } from "../../data/landing";
import { contact } from "../../data/contact";
import SocialIcon from "../SocialIcon.astro";

const whatsappUrl = `https://wa.me/${contact.whatsapp}`;
---

<section
  class="relative -mt-16 pt-16 min-h-svh w-full overflow-hidden bg-foreground"
  data-hero-parallax
>
  <img
    src={heroImage}
    alt="Modelo con camiseta oversize ApogeOv en fondo urbano, estilo streetwear Medellín"
    class="absolute inset-0 w-full h-full object-cover object-center opacity-40 will-change-transform"
    loading="eager"
    decoding="async"
  />

  <h1 class="sr-only">ApogeOv — Tienda online de ropa oversize premium en Medellín. Camisetas, sudaderas y combos de alta calidad para hombre. Envío gratis Valle de Aburrá.</h1>

  <div class="relative max-w-[1440px] mx-auto px-6 lg:px-[100px] h-full flex items-center pt-20 lg:pt-32">
    <div class="max-w-3xl animate-fade-in-up">
      <h2 class="text-4xl md:text-5xl lg:text-8xl font-black text-white mb-4 md:mb-6 leading-[0.95] tracking-tight">
        EL OVERSIZE<br />QUE BUSCABAS
      </h2>
      <p class="text-sm md:text-base lg:text-lg text-white/80 mb-6 md:mb-10 max-w-lg normal-case font-normal tracking-normal">
        Tela burda, alto gramaje. Paga cuando llega a tu casa.
      </p>
      <div class="flex flex-wrap gap-3 md:gap-4">
        <a
          href="#catalogo"
          class="inline-flex items-center gap-2 bg-white text-foreground px-6 md:px-8 py-3 md:py-4 text-xs md:text-sm uppercase tracking-wider hover:bg-accent hover:text-white transition-all"
        >
          Ver Catálogo
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#25D366] text-white px-6 md:px-8 py-3 md:py-4 text-xs md:text-sm uppercase tracking-wider hover:bg-[#20bd5a] transition-all"
        >
          <SocialIcon brand="whatsapp" variant="mono" class="h-4 w-4 md:h-5 md:w-5" />
          WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
