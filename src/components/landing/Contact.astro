---
// @ts-nocheck
import SocialIcon from "../SocialIcon.astro";
import { contact } from "../../data/contact";

const whatsappUrl = `https://wa.me/${contact.whatsapp}`;

const channelBtn =
  "contact-channel-btn flex w-full items-center gap-3 border border-border bg-card px-5 py-3.5 text-sm uppercase tracking-wider transition-all hover:border-accent hover:shadow-md outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-muted";

const channels = [
  { label: "WhatsApp", href: whatsappUrl, brand: "whatsapp", external: true },
  { label: "Instagram", href: contact.instagram, brand: "instagram", external: true },
  { label: "Email", href: `mailto:${contact.email}`, brand: "email", external: false },
  { label: "Facebook", href: contact.facebook, brand: "facebook", external: true },
  { label: "YouTube", href: contact.youtube, brand: "youtube", external: true },
  { label: "TikTok", href: contact.tiktok, brand: "tiktok", external: true },
];
---

<section class="bg-muted py-20 lg:py-28" id="contacto">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-[100px]">
    <div class="mb-8 md:mb-12">
      <h2 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl uppercase tracking-tight mb-3">Contáctanos</h2>
      <p class="text-muted-foreground normal-case font-normal tracking-normal max-w-xl">
        ¿Dudas sobre tallas, envíos o tu pedido? Envíanos un email o escríbenos por WhatsApp.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 lg:items-start">
      <div class="flex flex-col w-full">
        <h3 class="text-xs uppercase tracking-[0.2em] text-accent font-bold mb-5">Canales directos</h3>
        <nav class="flex flex-col gap-3 w-full" aria-label="Redes y contacto">
          {
            channels.map((channel) => (
              <a
                href={channel.href}
                class={channelBtn}
                {...(channel.external
                  ? { target: "_blank", rel: "noopener noreferrer" }
                  : {})}
              >
                <span class="flex h-6 w-6 shrink-0 items-center justify-center" aria-hidden="true">
                  <SocialIcon brand={channel.brand} class="h-6 w-6" />
                </span>
                <span>{channel.label}</span>
              </a>
            ))
          }
        </nav>

        <p class="mt-8 text-xs text-muted-foreground normal-case font-normal tracking-normal leading-relaxed">
          {contact.city} · Horario: lun–sáb, 9:00 a.m. – 7:00 p.m. · Envíos gratis en el Valle de Aburrá.
        </p>
      </div>

      <form
        class="bg-card border border-border p-6 lg:p-8 space-y-5"
        data-contact-form
        data-email={contact.email}
      >
        <div>
          <label for="contact-name" class="block text-xs uppercase tracking-wider mb-2">
            Nombre
          </label>
          <input
            id="contact-name"
            name="name"
            type="text"
            required
            autocomplete="name"
            maxlength="100"
            class="w-full border border-border bg-card px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
            placeholder="Tu nombre"
          />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="contact-email" class="block text-xs uppercase tracking-wider mb-2">
              Email
            </label>
            <input
              id="contact-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              maxlength="254"
              class="w-full border border-border bg-card px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
              placeholder="correo@ejemplo.com"
            />
          </div>
          <div>
            <label for="contact-phone" class="block text-xs uppercase tracking-wider mb-2">
              Teléfono
            </label>
            <input
              id="contact-phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              maxlength="20"
              class="w-full border border-border bg-card px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
              placeholder="+57 300 000 0000"
            />
          </div>
        </div>

        <div>
          <label for="contact-message" class="block text-xs uppercase tracking-wider mb-2">
            Mensaje
          </label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="4"
            maxlength="2000"
            class="w-full border border-border bg-card px-4 py-3 text-sm resize-y min-h-[120px] focus:outline-none focus:ring-2 focus:ring-accent"
            placeholder="Cuéntanos en qué podemos ayudarte..."
          ></textarea>
        </div>

        <button
          type="submit"
          data-contact-submit
          class="w-full bg-accent text-accent-foreground px-8 py-4 text-sm uppercase tracking-wider hover:brightness-110 transition-all disabled:opacity-60 disabled:cursor-not-allowed cursor-pointer"
        >
          Enviar email
        </button>

        <div data-form-success class="hidden text-center text-sm text-green-400 font-medium py-2">
          ✓ Tu mensaje fue enviado. Te contactaremos pronto.
        </div>

        <div data-form-error class="hidden text-center text-sm text-red-400 font-medium py-2">
          Error al enviar. Intenta de nuevo.
        </div>

        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex w-full items-center justify-center gap-2 bg-[#25D366] text-white px-8 py-4 text-sm uppercase tracking-wider hover:bg-[#20bd5a] transition-colors"
        >
          <SocialIcon brand="whatsapp" variant="mono" class="h-5 w-5" />
          Contáctanos por WhatsApp
        </a>
      </form>
    </div>
  </div>
</section>

<script>
  import "../../scripts/contact-form.ts";
</script>
