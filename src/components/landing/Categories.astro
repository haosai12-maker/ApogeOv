---
// @ts-nocheck
import Icon from "../Icon.astro";
import { loadProducts } from "../../data/load-products";

const featuredIds = ["producto-1", "producto-5", "producto-10"];
const productsById = Object.fromEntries(loadProducts().map((p) => [p.id, p]));
const featuredProducts = featuredIds
  .map((id) => productsById[id])
  .filter(Boolean);
---

<section class="max-w-[1440px] mx-auto px-6 lg:px-[100px] py-20 lg:py-28" id="destacados">
  <div class="featured-carousel overflow-hidden" data-featured-carousel>
    <div
      class="featured-inner flex gap-4 sm:gap-6 transition-transform duration-500 ease-in-out"
      data-featured-inner
    >
      {
        featuredProducts.map((product, index) => (
          <div
            class="featured-slide flex-shrink-0 w-[88%] max-w-[320px] sm:w-[calc(50%-12px)] sm:max-w-none lg:w-[calc(33.333%-16px)]"
            data-featured-slide
          >
            <a
              href="#catalogo"
              class="group relative block overflow-hidden aspect-[3/4] bg-muted"
              data-featured-product={product.id}
              aria-label={`Ver ${product.name} en Nuevos Drops`}
            >
              <img
                src={product.image}
                alt={`Camiseta oversize ${product.name} de ApogeOv — vista del producto`}
                class="absolute inset-0 w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
                loading={index === 0 ? "eager" : "lazy"}
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />

              <div class="absolute top-6 left-6">
                <span class="inline-block px-3 py-1 text-xs uppercase tracking-wider bg-accent text-white">
                  {product.fabric}
                </span>
              </div>

              <div class="absolute bottom-6 left-6 right-6">
                <h3 class="text-white text-lg md:text-xl lg:text-3xl font-black mb-2 uppercase leading-tight">
                  {product.name}
                </h3>
                <p class="text-white/90 text-base md:text-lg font-black mb-3 normal-case tracking-normal">
                  ${product.price} COP
                </p>
                <div class="flex items-center gap-2 text-white text-xs md:text-sm uppercase tracking-wide">
                  <span>Explorar</span>
                  <Icon
                    name="chevron-right"
                    class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                  />
                </div>
              </div>
            </a>
          </div>
        ))
      }
    </div>

    <div class="featured-carousel__dots flex justify-center gap-2 mt-6 lg:hidden" data-featured-dots></div>
  </div>
</section>

<script>
  import "../../scripts/featured-carousel.ts";
</script>

<style>
  .featured-carousel__dot {
    width: 0.5rem;
    height: 0.5rem;
    padding: 0;
    border: none;
    border-radius: 9999px;
    background: var(--border);
    cursor: pointer;
  }

  .featured-carousel__dot.is-active {
    background: var(--accent);
    transform: scale(1.2);
  }

  @media (min-width: 1024px) {
    .featured-inner {
      transform: none !important;
    }
  }
</style>
