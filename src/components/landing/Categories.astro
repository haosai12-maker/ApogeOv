---
// @ts-nocheck
import { loadProducts } from "../../data/load-products";

const featuredIds = ["producto-1", "producto-5", "producto-10"];
const productsById = Object.fromEntries(loadProducts().map((p) => [p.id, p]));
const featuredProducts = featuredIds
  .map((id) => productsById[id])
  .filter(Boolean);
---

<section class="bg-foreground text-white py-20 lg:py-32" id="destacados">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-[100px]">
    <div class="mb-10 md:mb-16 reveal-up">
      <span class="inline-block text-xs uppercase tracking-[0.2em] text-accent font-bold mb-2">
        Lo más vendido
      </span>
      <h2 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl uppercase tracking-tight">
        Selección Top
      </h2>
      <p class="text-sm md:text-base text-white/60 normal-case font-normal tracking-normal mt-2 max-w-lg">
        Las prendas que definen el estilo ApogeOv.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 stagger-children">
      {
        featuredProducts.map((product, index) => (
          <a
            href="#catalogo"
            class="featured-editorial-card group relative overflow-hidden grain-overlay"
            data-featured-product={product.id}
            aria-label={`Ver ${product.name} en el catálogo`}
          >
            <img
              src={product.image}
              alt={`${product.name} de ApogeOv — producto destacado`}
              class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out group-hover:scale-105"
              loading={index === 0 ? "eager" : "lazy"}
              decoding="async"
            />

            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-black/10 z-[1] transition-opacity duration-500 group-hover:from-black/95" />

            <div class="absolute top-6 left-6 z-[2]">
              <span class="inline-block px-3 py-1 text-[0.6rem] uppercase tracking-[0.15em] font-bold bg-accent text-accent-foreground">
                {product.fabric}
              </span>
            </div>

            <div class="absolute bottom-0 left-0 right-0 z-[2] p-6 md:p-8 transition-transform duration-500 group-hover:translate-y-[-4px]">
              <h3 class="font-display text-2xl md:text-3xl font-bold uppercase tracking-tight mb-2 leading-tight">
                {product.name}
              </h3>
              <p class="text-accent text-xl md:text-2xl font-black mb-4 normal-case tracking-normal">
                ${product.price} COP
              </p>
              <div class="flex items-center gap-2 text-xs uppercase tracking-[0.15em] text-white/80">
                <span>Ir al catálogo</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 group-hover:translate-x-1 transition-transform">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .featured-editorial-card {
    aspect-ratio: 3 / 4;
    min-height: 380px;
  }

  @media (min-width: 768px) {
    .featured-editorial-card {
      aspect-ratio: 2 / 3;
      min-height: 480px;
    }
  }

  @media (min-width: 1024px) {
    .featured-editorial-card {
      min-height: 560px;
    }
  }
</style>
