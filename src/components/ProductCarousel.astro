---
interface Props {
  images: string[];
  alt: string;
  compact?: boolean;
}

const { images, alt, compact = false } = Astro.props;
const hasMultiple = images.length > 1;
const carouselId = `carousel-${Math.random().toString(36).slice(2, 9)}`;
---

{
  images.length > 0 ? (
    <div
      class:list={["product-carousel", compact && "product-carousel--compact"]}
      data-product-carousel
      data-carousel-id={carouselId}
      data-images={JSON.stringify(images)}
    >
      <div class="product-carousel__viewport">
        <div class="product-carousel__track" data-carousel-track>
          {
            images.map((src, index) => (
              <div
                class:list={["product-carousel__slide", index === 0 && "is-active"]}
                data-carousel-slide
                data-index={index}
              >
                <img
                  src={src}
                  alt={`${alt} — foto ${index + 1}`}
                  class="product-carousel__img"
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                  draggable="false"
                />
              </div>
            ))
          }
        </div>
      </div>

      {
        hasMultiple && (
          <div class="product-carousel__controls" aria-hidden="false">
            <button
              type="button"
              class="product-carousel__nav product-carousel__nav--prev"
              data-carousel-prev
              aria-label="Foto anterior"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="m15 18-6-6 6-6" />
              </svg>
            </button>
            <button
              type="button"
              class="product-carousel__nav product-carousel__nav--next"
              data-carousel-next
              aria-label="Foto siguiente"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </button>
            <div class="product-carousel__counter" data-carousel-counter>
              1 / {images.length}
            </div>
          </div>
        )
      }

      {
        hasMultiple && (
          <div class="product-carousel__dots" data-carousel-dots>
            {
              images.map((_, index) => (
                <button
                  type="button"
                  class:list={["product-carousel__dot", index === 0 && "is-active"]}
                  data-carousel-dot={index}
                  aria-label={`Ir a foto ${index + 1}`}
                />
              ))
            }
          </div>
        )
      }
    </div>
  ) : (
    <div class="product-carousel product-carousel--empty">
      <span class="text-xs uppercase tracking-wider text-muted-foreground">Sin imagen</span>
    </div>
  )
}

