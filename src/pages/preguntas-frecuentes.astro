---
import SiteLayout from "../layouts/SiteLayout.astro";
import FAQ from "../components/landing/FAQ.astro";
import SizeChart from "../components/landing/SizeChart.astro";

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://apogeov.com/",
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Preguntas Frecuentes",
      "item": "https://apogeov.com/preguntas-frecuentes",
    },
  ],
});
---

<script type="application/ld+json" set:html={breadcrumbSchema}></script>

<SiteLayout
  title="Preguntas Frecuentes — Envíos, Tallas y Pagos | ApogeOv Medellín"
  description="Resolvemos todas tus dudas: envíos gratis en Medellín y Valle de Aburrá, guía de tallas exactas, pago contraentrega. Compra seguro en ApogeOv."
  canonicalUrl="https://apogeov.com/preguntas-frecuentes"
>
  <FAQ />
  <SizeChart />
</SiteLayout>
